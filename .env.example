# Copy to .env and fill in. Loaded by src/bot.ts via dotenv.

# Telegram bot token from @BotFather
TOKEN=

# MongoDB connection string (users, awards, lotteries)
MONGO=mongodb://localhost:27017/viz-dice-bot

# VIZ blockchain account that pays awards/lottery winners
ACCOUNT=
# Active private key (WIF) for ACCOUNT — keep secret, signs transactions
WIF=

# Cooldown between a user's /play rolls, in minutes
MINUTES=5

# Lottery round length, in hours (winners drawn every LOTTERY_HOURS)
LOTTERY_HOURS=24

# Target vesting_shares balance; surplus above this is unstaked daily
BALANCE=

# "false" enables dev mode (fast lottery cadence, replay recent blocks);
# any other value runs in production cadence
PRODUCTION=true
