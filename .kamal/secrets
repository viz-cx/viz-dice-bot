# shellcheck shell=bash
# shellcheck disable=SC2034  # Vars consumed by Kamal externally.
# Pulls credentials from the sibling infra repo's SOPS files. Kamal parses this
# with dotenv (NOT bash): plain assignment + $(...) work, but ${VAR:-default}
# does not — keep INFRA a literal.
INFRA=../../infra

# GHCR registry password — a GitHub PAT (write:packages), shared across all apps.
KAMAL_REGISTRY_PASSWORD=$(sops -d --extract '["docker_registry_password"]' "$INFRA/secrets/shared.enc.yaml")

# dice app secrets — secrets/apps/dice.enc.yaml. db_uri generated by
# scripts/add-app.sh (axveer mongo user `dice`, readWrite on db dice); bot_token +
# wif_key pulled from the legacy .env. SOPS key names hit encrypted_regex
# (_uri / _token / _key) so they encrypt at rest — WIF is stored under wif_key
# because the bare name `wif` does not match the regex.
MONGO=$(sops -d --extract '["db_uri"]' "$INFRA/secrets/apps/dice.enc.yaml")
TOKEN=$(sops -d --extract '["bot_token"]' "$INFRA/secrets/apps/dice.enc.yaml")
WIF=$(sops -d --extract '["wif_key"]' "$INFRA/secrets/apps/dice.enc.yaml")
