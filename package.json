{
  "name": "viz-dice-bot",
  "version": "1.0.0",
  "description": "Telegram bot with dice game on VIZ blockchain",
  "main": "dist/app.js",
  "repository": "https://github.com/viz-cx/viz-dice-bot",
  "author": "Vladimir Babin",
  "license": "MIT",
  "private": false,
  "scripts": {
    "distribute": "yarn build-ts && node dist/app.js",
    "develop": "concurrently -k -i -p \"[{name}]\" -n \"Node,TypeScript\" -c \"yellow.bold,cyan.bold\" \"yarn watch-js\" \"yarn watch-ts\"",
    "build-ts": "tsc --skipLibCheck",
    "watch-ts": "tsc -w --skipLibCheck",
    "watch-js": "nodemon dist/app.js --ext js,yaml",
    "test": "vitest run",
    "test-watch": "vitest",
    "update": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@typegoose/typegoose": "^13.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.1",
    "eslint": "^10",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@viz-cx/core": "^0.5.2",
    "dotenv": "^17.4.2",
    "grammy": "^1.43.0",
    "js-yaml": "^4.2.0",
    "markdown-table-ts": "^1.0.3",
    "mongoose": "^9.6.0",
    "typescript": "^6.0.3",
    "viz-js-lib": "^0.12.6"
  },
  "resolutions": {
    "//": "Neutralize advisories from viz-js-lib's dependency tree (we never import viz-js-lib directly; it is a peer dep of @viz-cx/core). babel-preset-env and cross-env are build/script tooling wrongly listed in viz-js-lib's runtime deps and are never loaded at runtime, so we stub them. The rest are real transitive crypto utils pinned to their patched versions. Drop these once VIZ-Blockchain/viz-js-lib ships a release with the fixes.",
    "viz-js-lib/babel-preset-env": "npm:@favware/skip-dependency@1.2.2",
    "viz-js-lib/cross-env": "npm:@favware/skip-dependency@1.2.2",
    "sha.js": "^2.4.12",
    "cipher-base": "^1.0.5",
    "base-x": "^3.0.11"
  }
}
