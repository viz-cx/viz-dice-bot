{
  "name": "viz-dice-bot",
  "version": "1.0.0",
  "description": "Telegram bot with dice game on VIZ blockchain",
  "main": "dist/app.js",
  "repository": "https://github.com/viz-cx/viz-dice-bot",
  "author": "Vladimir Babin",
  "license": "MIT",
  "private": false,
  "scripts": {
    "distribute": "yarn build-ts && node dist/app.js",
    "develop": "concurrently -k -i -p \"[{name}]\" -n \"Node,TypeScript\" -c \"yellow.bold,cyan.bold\" \"yarn watch-js\" \"yarn watch-ts\"",
    "build-ts": "tsc --skipLibCheck",
    "watch-ts": "tsc -w --skipLibCheck",
    "watch-js": "nodemon dist/app.js --ext js,yaml",
    "update": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@typegoose/typegoose": "^13.2.1",
    "@types/mongoose": "^5.11.97",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "dotenv": "^17.3.1",
    "markdown-table-ts": "^1.0.3",
    "mongoose": "^9",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "typescript": "<6.0.0",
    "viz-js-lib": "^0.11.0"
  }
}